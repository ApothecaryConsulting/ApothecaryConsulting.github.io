---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contactLinks } from '../data/contact';
---

<Layout title="Contact Us - Apothecary Consulting">
	<Header />

	<div class="page-hero">
		<div class="hero-badge">Get In Touch</div>
		<h1>Let's <span class="gradient-text">Connect</span></h1>
		<p>Ready to transform your data and AI capabilities? We'd love to hear from you.</p>
	</div>

	<div class="container">
		<div class="contact-section">
			<div class="contact-intro">
				<p>
					Whether you're looking to build AI-powered solutions, optimize your data infrastructure,
					or explore how machine learning can drive your business forward, our team is here to help.
				</p>
				<p>
					Reach out through any of the channels below and we'll get back to you promptly
					to discuss your project needs.
				</p>
			</div>

			<div class="contact-methods">
				{contactLinks.map((link) => (
					<a href={link.url} class="contact-card" target="_blank" rel="noopener noreferrer">
						<div class="contact-icon">{link.label.includes('Email') ? '✉️' : link.label.includes('LinkedIn') ? '🔗' : '💻'}</div>
						<h3>{link.label}</h3>
						<p>Connect with us on {link.label}</p>
					</a>
				))}
			</div>

			<div class="info-section">
				<h2>What to Expect</h2>
				<div class="info-grid">
					<div class="info-card">
						<div class="info-number">01</div>
						<h3>Initial Consultation</h3>
						<p>We'll discuss your business needs, challenges, and goals to understand how we can help.</p>
					</div>
					<div class="info-card">
						<div class="info-number">02</div>
						<h3>Proposal & Planning</h3>
						<p>Receive a detailed proposal with timeline, deliverables, and transparent pricing.</p>
					</div>
					<div class="info-card">
						<div class="info-number">03</div>
						<h3>Implementation</h3>
						<p>Our team works closely with you to deliver high-quality solutions on time.</p>
					</div>
					<div class="info-card">
						<div class="info-number">04</div>
						<h3>Support & Growth</h3>
						<p>Ongoing support and optimization to ensure long-term success.</p>
					</div>
				</div>
			</div>

			<div class="cta-section">
				<h2>Ready to Get Started?</h2>
				<p>Let's build something amazing together.</p>
				<div class="btn-container">
					{contactLinks.map((link) => (
						<a href={link.url} class="btn-primary" target="_blank" rel="noopener noreferrer">{link.label}</a>
					))}
				</div>
			</div>
		</div>
	</div>

	<Footer />
</Layout>

<style>
	.page-hero {
		text-align: center;
		padding: 90px 20px 50px;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(56, 189, 248, 0.1);
		border: 1px solid rgba(56, 189, 248, 0.25);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-blue);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin-bottom: 24px;
	}

	.page-hero h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		margin: 0 auto 20px;
		letter-spacing: -0.02em;
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--accent-blue), var(--accent-indigo));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-hero p {
		font-size: 18px;
		color: var(--text-muted);
		max-width: 680px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.contact-section {
		max-width: 1000px;
		margin: 0 auto;
	}

	.contact-intro {
		text-align: center;
		margin-bottom: 56px;
		max-width: 760px;
		margin-left: auto;
		margin-right: auto;
	}

	.contact-intro p {
		font-size: 17px;
		line-height: 1.8;
		color: var(--text-muted);
		margin-bottom: 12px;
	}

	.contact-methods {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 20px;
		margin-bottom: 72px;
	}

	.contact-card {
		background: var(--bg-card);
		padding: 36px 24px;
		border-radius: 14px;
		border: 1px solid var(--border);
		text-align: center;
		text-decoration: none;
		transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
		backdrop-filter: blur(8px);
	}

	.contact-card:hover {
		transform: translateY(-4px);
		border-color: var(--border-hover);
		box-shadow: 0 8px 32px rgba(56, 189, 248, 0.12);
	}

	.contact-icon {
		font-size: 40px;
		margin-bottom: 16px;
	}

	.contact-card h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 20px;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 8px;
	}

	.contact-card p {
		font-size: 14px;
		color: var(--text-subtle);
		margin: 0;
	}

	.info-section {
		margin-bottom: 72px;
	}

	.info-section h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 30px;
		font-weight: 700;
		margin-bottom: 40px;
		color: var(--text-primary);
		text-align: center;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 20px;
	}

	.info-card {
		background: var(--bg-card);
		padding: 28px 24px;
		border-radius: 12px;
		border: 1px solid var(--border);
		text-align: center;
	}

	.info-number {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--accent-blue);
		margin-bottom: 14px;
	}

	.info-card h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 17px;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 10px;
	}

	.info-card p {
		font-size: 14px;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0;
	}

	.cta-section {
		text-align: center;
		background: var(--bg-card);
		padding: 56px 40px;
		border-radius: 16px;
		border: 1px solid var(--border);
	}

	.cta-section h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 30px;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 12px;
	}

	.cta-section p {
		font-size: 17px;
		color: var(--text-muted);
		margin-bottom: 32px;
	}

	.btn-container {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 14px;
	}

	@media screen and (max-width: 768px) {
		.page-hero h1 {
			font-size: 32px;
		}

		.contact-methods {
			grid-template-columns: 1fr;
		}

		.info-grid {
			grid-template-columns: 1fr;
		}

		.btn-container {
			flex-direction: column;
			align-items: center;
		}

		.btn-primary {
			width: 80%;
			text-align: center;
		}
	}
</style>
