---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Apothecary Consulting">
	<Header />

	<div class="page-hero">
		<div class="hero-badge">Our Story</div>
		<h1>About <span class="gradient-text">Apothecary Consulting</span></h1>
		<p>Empowering businesses with next-generation AI, data engineering, and cloud technologies</p>
	</div>

	<div class="container">
		<div class="section">
			<h2>Who We Are</h2>
			<p class="intro-text">
				Apothecary Consulting is a boutique data engineering and AI firm built by practitioners — engineers
				who have shipped pipelines at Uber Eats, built systems on $429M government contracts at Northrop
				Grumman, and deployed LLM-powered applications in production. We work with organizations that need
				senior-level expertise without the overhead of a large agency.
			</p>
		</div>

		<div class="section">
			<h2>Our Mission</h2>
			<p class="intro-text">
				Our mission is straightforward: bring the caliber of data and AI engineering you'd find at a top
				technology company to the organizations that need it most — but can't staff or retain that talent
				internally. We operate as embedded technical partners, not order-takers. That means we tell you
				when an approach won't work and propose something better.
			</p>
		</div>

		<div class="section">
			<h2>Who We Work With</h2>
			<p class="intro-text">
				We're a strong fit for engineering-led organizations navigating a specific inflection point: your
				data is growing faster than your team's ability to manage it, or you're moving AI out of pilot and
				into production and need the infrastructure to back it up. Our clients typically include
				growth-stage technology companies, government contractors with data-intensive programs, and R&D
				teams in life sciences and defense who need rigorous, secure data pipelines.
			</p>
		</div>

		<div class="section">
			<h2>What Sets Us Apart</h2>
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-icon">🎯</div>
					<h3>Proven Track Record</h3>
					<p>Our team has delivered measurable results including 20% sales increases, $429M government contracts, and enterprise-scale deployments.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🔬</div>
					<h3>Technical Excellence</h3>
					<p>Deep expertise in Python, AWS, GCP, machine learning, and modern data stack technologies like DBT, Airflow, and Snowflake.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🚀</div>
					<h3>End-to-End Solutions</h3>
					<p>From initial consultation to deployment and maintenance, we handle every aspect of your AI and data engineering needs.</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">🔬</div>
					<h3>Practitioners, Not Presenters</h3>
					<p>Every engagement is led by the engineers who built the solution — not handed off to junior staff after the sales call. You work with the same people from scoping to delivery.</p>
				</div>
			</div>
		</div>

		<div class="section">
			<h2>Our Expertise</h2>
			<div class="expertise-list">
				<div class="expertise-item">
					<span class="expertise-label">AI & Machine Learning</span>
					<span class="expertise-desc">Custom AI chatbots, voice AI, model training, and LLM integration</span>
				</div>
				<div class="expertise-item">
					<span class="expertise-label">Data Engineering</span>
					<span class="expertise-desc">ETL/ELT pipelines, data warehousing, real-time processing, and data quality</span>
				</div>
				<div class="expertise-item">
					<span class="expertise-label">Cloud Infrastructure</span>
					<span class="expertise-desc">AWS, GCP, Azure deployment, scalable architecture, and DevOps automation</span>
				</div>
				<div class="expertise-item">
					<span class="expertise-label">Security & Compliance</span>
					<span class="expertise-desc">AI security, data encryption, API security, and risk mitigation</span>
				</div>
				<div class="expertise-item">
					<span class="expertise-label">Full-Stack Development</span>
					<span class="expertise-desc">AI-powered applications, REST APIs, and modern web technologies</span>
				</div>
			</div>
		</div>

		<div class="section cta-section">
			<h2>Ready to Transform Your Data?</h2>
			<p>Let's discuss how we can help your organization leverage AI and data engineering to achieve your goals.</p>
			<a href="/contact" class="btn-primary">Get in Touch</a>
		</div>
	</div>

	<Footer />
</Layout>

<style>
	.page-hero {
		text-align: center;
		padding: 90px 20px 50px;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(56, 189, 248, 0.1);
		border: 1px solid rgba(56, 189, 248, 0.25);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-blue);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin-bottom: 24px;
	}

	.page-hero h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		margin: 0 auto 20px;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--accent-blue), var(--accent-indigo));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-hero p {
		font-size: 18px;
		color: var(--text-muted);
		max-width: 680px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.section {
		margin-bottom: 72px;
	}

	.section h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 30px;
		font-weight: 700;
		margin-bottom: 20px;
		color: var(--text-primary);
		text-align: center;
	}

	.intro-text {
		font-size: 17px;
		line-height: 1.8;
		color: var(--text-muted);
		max-width: 860px;
		margin: 0 auto;
		text-align: center;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 24px;
		margin-top: 40px;
	}

	.feature-card {
		background: var(--bg-card);
		padding: 28px 24px;
		border-radius: 14px;
		border: 1px solid var(--border);
		backdrop-filter: blur(8px);
		transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
	}

	.feature-card:hover {
		transform: translateY(-4px);
		border-color: var(--border-hover);
		box-shadow: 0 8px 32px rgba(56, 189, 248, 0.08);
	}

	.feature-icon {
		font-size: 28px;
		margin-bottom: 14px;
	}

	.feature-card h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 18px;
		font-weight: 700;
		margin: 0 0 10px;
		color: var(--text-primary);
	}

	.feature-card p {
		font-size: 14px;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
	}

	.expertise-list {
		display: flex;
		flex-direction: column;
		gap: 12px;
		max-width: 820px;
		margin: 32px auto 0;
	}

	.expertise-item {
		display: flex;
		align-items: baseline;
		gap: 16px;
		background: var(--bg-card);
		padding: 18px 24px;
		border-radius: 10px;
		border: 1px solid var(--border);
	}

	.expertise-label {
		font-weight: 700;
		font-size: 15px;
		color: var(--accent-blue);
		white-space: nowrap;
		min-width: 200px;
	}

	.expertise-desc {
		font-size: 15px;
		color: var(--text-muted);
		line-height: 1.55;
	}

	.cta-section {
		text-align: center;
		background: var(--bg-card);
		padding: 56px 40px;
		border-radius: 16px;
		border: 1px solid var(--border);
	}

	.cta-section h2 {
		margin-bottom: 14px;
	}

	.cta-section p {
		font-size: 17px;
		color: var(--text-muted);
		margin-bottom: 32px;
		line-height: 1.7;
	}

	@media screen and (max-width: 768px) {
		.page-hero h1 {
			font-size: 32px;
		}

		.features-grid {
			grid-template-columns: 1fr;
		}

		.expertise-item {
			flex-direction: column;
			gap: 6px;
		}

		.expertise-label {
			min-width: unset;
		}
	}
</style>
