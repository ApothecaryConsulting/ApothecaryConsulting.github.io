---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { team } from '../data/team';
---

<Layout title="Our Team - Apothecary Consulting">
	<Header />

	<div class="page-hero">
		<div class="hero-badge">The People</div>
		<h1>Meet the <span class="gradient-text">Team</span></h1>
		<p>Expert engineers and data scientists dedicated to delivering exceptional AI and data solutions</p>
	</div>

	<div class="container">
		<div class="team-grid">
			{team.map((member) => (
				<div class="team-member">
					<div class="member-header">
						<img src={member.imageUrl} alt={member.name} class="member-image" />
						<div class="member-info">
							<h2>{member.name}</h2>
							<h3 class="role">{member.role}</h3>
							<p class="title">{member.title}</p>
						</div>
					</div>
					<p class="description">{member.description}</p>

					<div class="skills">
						<h4>Key Skills</h4>
						<div class="skills-tags">
							{member.skills.map((skill) => (
								<span class="skill-tag">{skill}</span>
							))}
						</div>
					</div>

					<div class="contact-links">
						{member.linkedin && (
							<a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="contact-btn">
								<span>🔗</span> LinkedIn
							</a>
						)}
						{member.email && (
							<a href={`mailto:${member.email}`} class="contact-btn">
								<span>✉️</span> Email
							</a>
						)}
					</div>
				</div>
			))}
		</div>
	</div>

	<Footer />
</Layout>

<style>
	.page-hero {
		text-align: center;
		padding: 90px 20px 50px;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(56, 189, 248, 0.1);
		border: 1px solid rgba(56, 189, 248, 0.25);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-blue);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin-bottom: 24px;
	}

	.page-hero h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		margin: 0 auto 20px;
		letter-spacing: -0.02em;
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--accent-blue), var(--accent-indigo));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-hero p {
		font-size: 18px;
		color: var(--text-muted);
		max-width: 680px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
		gap: 32px;
		margin-top: 20px;
	}

	.team-member {
		background: var(--bg-card);
		padding: 32px 28px;
		border-radius: 16px;
		border: 1px solid var(--border);
		backdrop-filter: blur(8px);
		transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
	}

	.team-member:hover {
		transform: translateY(-4px);
		border-color: var(--border-hover);
		box-shadow: 0 8px 32px rgba(56, 189, 248, 0.1);
	}

	.member-header {
		display: flex;
		gap: 20px;
		margin-bottom: 20px;
		align-items: flex-start;
	}

	.member-image {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid rgba(56, 189, 248, 0.3);
		flex-shrink: 0;
	}

	.member-info h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 4px;
		color: var(--text-primary);
	}

	.role {
		font-size: 14px;
		font-weight: 700;
		color: var(--accent-blue);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin: 0 0 4px;
	}

	.title {
		font-size: 13px;
		color: var(--text-subtle);
		font-style: italic;
		margin: 0;
	}

	.description {
		font-size: 15px;
		line-height: 1.65;
		color: var(--text-muted);
		margin: 0 0 22px;
	}

	.skills h4 {
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-subtle);
		margin: 0 0 10px;
	}

	.skills-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
		margin-bottom: 22px;
	}

	.skill-tag {
		background: rgba(56, 189, 248, 0.08);
		color: var(--accent-blue);
		padding: 5px 12px;
		border-radius: 100px;
		font-size: 12px;
		font-weight: 600;
		border: 1px solid rgba(56, 189, 248, 0.18);
	}

	.contact-links {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		border-top: 1px solid var(--border);
		padding-top: 20px;
	}

	.contact-btn {
		padding: 9px 18px;
		background: linear-gradient(135deg, var(--accent-blue), var(--accent-indigo));
		color: #050b18;
		font-weight: 700;
		text-decoration: none;
		border-radius: 8px;
		font-size: 13px;
		display: flex;
		align-items: center;
		gap: 6px;
		transition: opacity 0.2s, transform 0.2s;
		box-shadow: 0 0 14px rgba(56, 189, 248, 0.2);
	}

	.contact-btn:hover {
		opacity: 0.9;
		transform: translateY(-1px);
	}

	@media screen and (max-width: 768px) {
		.page-hero h1 {
			font-size: 32px;
		}

		.team-grid {
			grid-template-columns: 1fr;
		}

		.member-header {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
	}
</style>
