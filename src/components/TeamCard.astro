---
interface Props {
	name: string;
	role: string;
	description: string;
	imageUrl: string;
}

const { name, role, description, imageUrl } = Astro.props;
---

<div class="card">
	<img src={imageUrl} alt={`${name} - ${role}`} class="avatar">
	<h3>{name}</h3>
	<span class="role">{role}</span>
	<p>{description}</p>
</div>

<style>
	.card {
		background: var(--bg-card);
		padding: 28px 24px;
		border-radius: 14px;
		border: 1px solid var(--border);
		text-align: center;
		backdrop-filter: blur(8px);
		transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
	}

	.card:hover {
		transform: translateY(-4px);
		border-color: var(--border-hover);
		box-shadow: 0 8px 32px rgba(56, 189, 248, 0.1);
	}

	.avatar {
		width: 88px;
		height: 88px;
		border-radius: 50%;
		object-fit: cover;
		margin-bottom: 16px;
		border: 2px solid rgba(56, 189, 248, 0.3);
	}

	h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 20px;
		font-weight: 700;
		margin: 0 0 6px;
		color: var(--text-primary);
	}

	.role {
		display: block;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-blue);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 14px;
	}

	p {
		font-size: 14px;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
	}
</style>
